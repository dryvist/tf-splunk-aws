# Backend configuration for the prod environment.
# Replace <ACCOUNT_ID> with your 12-digit AWS account id, then:
#   tofu init -backend-config=envs/prod.s3.tfbackend
bucket       = "tf-splunk-aws-state-us-east-2-<ACCOUNT_ID>"
key          = "tf-splunk-aws/prod/terraform.tfstate"
region       = "us-east-2"
encrypt      = true
use_lockfile = true
