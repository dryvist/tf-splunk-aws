# --- OpenTofu ----------------------------------------------------------------
.terraform/
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# tfvars can carry secrets — ignored by default. The committed per-environment
# files under envs/ are the deliberate exception: they hold only non-secret
# defaults (secrets come from TF_VAR_* environment variables).
*.tfvars
*.tfvars.json
!envs/*.tfvars
!*.tfvars.example

# Lambda build artifacts (generated at plan time by data.archive_file)
**/.build/

